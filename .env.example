# === AWS Configuration ===
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# === API URL (set after deploying API to Lambda) ===
VITE_API_URL=https://your-api-id.execute-api.ap-northeast-1.amazonaws.com/api

# === DynamoDB Table Names (auto-set by serverless) ===
CONTENT_TABLE=magpiecert-api-content-prod
COURSES_TABLE=magpiecert-api-courses-prod
NEWS_TABLE=magpiecert-api-news-prod
DOWNLOADS_TABLE=magpiecert-api-downloads-prod
CERTIFICATES_TABLE=magpiecert-api-certificates-prod
RECRUITMENT_TABLE=magpiecert-api-recruitment-prod
